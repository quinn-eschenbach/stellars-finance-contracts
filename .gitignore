/target
node_modules/
packages/*/dist/
# packages/bindings/ is NOT gitignored — the docker images expect the
# generated TS to be present without dragging Rust + the stellar CLI into
# the build context. Run `make bind` after any contract change and commit
# the resulting drift; per-binding dist/ folders sit one level deeper than
# the `packages/*/dist/` glob, so they're tracked alongside src/.
*.tgz
.env
.env.*
!.env.example
packages/simulation/state/

# Soroban test snapshots — auth/state recordings regenerated on every cargo
# test run. WASM build non-determinism makes them churn locally even when
# behavior is unchanged, so they're not useful as tracked artifacts.
test-suites/test_snapshots/
contracts/*/test_snapshots/

.DS_Store
